{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": true,
    "strict": true,
    "rootDir": "src",
    "outDir": "expected",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "src/**/*.mts"
  ]
}
